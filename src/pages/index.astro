---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Fix emoji rendering -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">

    <title>The Milan Post</title>
  </head>

  <body>
    <main>
      <p class="tag">MILAN, EXPLAINED</p>

      <h1>The Milan Post</h1>

      <p class="subtitle">
        Practical guides for living in Milan — paperwork, housing, healthcare,
        and daily life for expats.
      </p>

      <p class="status">🚧 Work in progress</p>

      <div class="actions">
        <a href="#">Start here</a>
        <a href="#">Guides</a>
      </div>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI Emoji", "Apple Color Emoji", sans-serif;

    background:
      radial-gradient(circle at top left, #f97316 0, transparent 30%),
      linear-gradient(135deg, #0f172a, #020617);

    color: white;
    min-height: 100vh;
  }

  main {
    max-width: 820px;
    margin: 0 auto;
    padding: 100px 24px;
  }

  .tag {
    color: #facc15;
    font-size: 13px;
    letter-spacing: 0.15em;
    font-weight: 700;
  }

  h1 {
    font-size: clamp(54px, 8vw, 100px);
    line-height: 0.9;
    margin: 16px 0 24px;
  }

  .subtitle {
    font-size: 20px;
    color: #cbd5f5;
    max-width: 600px;
    line-height: 1.5;
  }

  .status {
    margin-top: 32px;
    font-size: 18px;
    opacity: 0.9;
  }

  .actions {
    margin-top: 40px;
    display: flex;
    gap: 16px;
  }

  .actions a {
    padding: 14px 22px;
    border-radius: 12px;
    text-decoration: none;
    color: white;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    font-weight: 600;
  }

  .actions a:hover {
    background: rgba(255,255,255,0.2);
  }
</style>